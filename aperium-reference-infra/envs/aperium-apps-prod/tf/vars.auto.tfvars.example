# Copy to vars.auto.tfvars and replace the repo URL, GitHub App values, project IDs, and CIDRs for your environment.
gcp_project_id = "YOUR_GCP_PROJECT_ID"
gcp_region     = "YOUR_GCP_REGION"
gcp_zone       = "YOUR_GCP_ZONE"

env_name     = "prod"
network_cidr = "10.205.0.0/16"
service_cidr = "172.27.0.0/20"
pod_cidr     = "172.28.0.0/20"
nat_ip_count = 1

dns_domains = [
  "apps.YOUR_DOMAIN.",
]

git_repo_url               = "https://github.com/YOUR_ORG/aperium-reference-infra.git"
github_app_id              = "YOUR_GITHUB_APP_ID"
github_app_installation_id = "YOUR_GITHUB_APP_INSTALLATION_ID"

# Set github_app_private_key as a sensitive terraform variable in the Terraform Cloud workspace.
argocd_ingress_enabled = false
argocd_admin_enabled   = true
argo_sso_enabled       = false
